#!/usr/bin/env python3
import os
import sys
from pathlib import Path

BASE_DIR = Path(__file__).parent.parent
sys.path.append(str(BASE_DIR / "scripts"))
 
try:
    import jdk
    import jre
except ImportError as e:
    sys.exit(1)

def main():
    if len(sys.argv) < 3:
        sys.exit(1)
        
    layers_dir = Path(sys.argv[1])
    version = "21" 

    jvm_type = os.getenv("BP_JVM_TYPE", "JRE").upper()
    is_jdk_mode = (jvm_type == "JDK")

    if is_jdk_mode:
        if not jdk.install_jdk(layers_dir, version, launch=True):
            sys.exit(1)
    else:
        if not jdk.install_jdk(layers_dir, version, launch=False):
            sys.exit(1)
        if not jre.install_jre_fips(layers_dir, version, is_jdk_mode=False):
            sys.exit(1)

    runtime_layer_name = "jdk" if is_jdk_mode else "jre"
    java_bin = str(layers_dir / runtime_layer_name / "bin" / "java")
    launch_toml = layers_dir / "launch.toml"
    
    processes_content = f"""

[[processes]]
type = "check-java"
command = "{java_bin}"
args = ["-version"]
direct = true

[[processes]]
type = "heap-info"
command = "{java_bin}"
args = ["-XshowSettings:vm", "-version"]
direct = true
"""
    
    with open(launch_toml, "w") as f:
        f.write(processes_content)

    sys.exit(0)

if __name__ == "__main__":
    main()